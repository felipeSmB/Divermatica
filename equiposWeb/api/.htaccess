# Bloquear acesso direto ao ficheiro .env
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

# Bloquear acesso a ficheiros sensíveis
<FilesMatch "\.(env|log|sh|sql|bak|zip)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear acesso direto à pasta middleware
<Files "rate_limit.php">
    Order allow,deny
    Deny from all
</Files>
<Files "jwt.php">
    Order allow,deny
    Deny from all
</Files>
<Files "validate.php">
    Order allow,deny
    Deny from all
</Files>

# Desativar listagem de diretórios
Options -Indexes